<!-- views/partials/footer.ejs -->
<style>
    /* Estilos base para a Notificação (Urgência/Prova Social) */
    #sale-notification {
        position: fixed;
        bottom: 20px;
        left: 20px;
        display: none; /* Controlado pelo JS */
        z-index: 9999;
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        border-radius: 12px;
        padding: 16px;
        align-items: center;
        gap: 16px;
        max-width: 380px;
        font-family: 'Outfit', 'Segoe UI', Roboto, sans-serif;
        box-sizing: border-box;
    }

    #sale-notification .sale-icon-box {
        background-color: #dcfce7;
        color: #16a34a;
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    #sale-notification .sale-info-box {
        display: flex;
        flex-direction: column;
    }

    #sale-notification #sale-product {
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 4px 0;
        line-height: 1.25;
    }

    #sale-notification .sale-meta-text {
        font-size: 12px;
        color: #64748b;
        margin: 0;
    }

    #sale-notification .sale-meta-text .font-medium {
        font-weight: 500;
    }

    #sale-notification .sale-meta-text #sale-time {
        color: #334155;
    }

    /* Estilos base para o Rodapé */
    .custom-footer {
        background-color: #0f172a;
        color: #94a3b8;
        padding: 48px 0;
        border-top: 1px solid #1e293b;
        font-family: 'Outfit', 'Segoe UI', Roboto, sans-serif;
        box-sizing: border-box;
        width: 100%;
    }

    .custom-footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        box-sizing: border-box;
    }

    @media (min-width: 768px) {
        .custom-footer-container {
            flex-direction: row;
        }
    }

    .custom-footer-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .custom-footer-logo {
        height: 32px;
        filter: grayscale(100%);
        opacity: 0.7;
    }

    .custom-footer-copyright {
        font-size: 14px;
        margin: 0;
    }

    .custom-footer-links {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
    }

    @media (min-width: 640px) {
        .custom-footer-links {
            flex-direction: row;
        }
    }

    .custom-footer-social {
        display: flex;
        gap: 16px;
        font-size: 20px;
    }

    .custom-footer-social a {
        color: #94a3b8;
        text-decoration: none;
        transition: color 0.2s;
    }

    .custom-footer-social a:hover {
        color: #ffffff;
    }
</style>

<!-- Sale Notification -->
<div id="sale-notification"
    class="bg-white border border-slate-200 shadow-2xl rounded-xl p-4 items-center gap-4 max-w-sm transform transition-all translate-y-0 opacity-100">
    <div
        class="bg-green-100 text-green-600 w-12 h-12 flex-shrink-0 rounded-full flex items-center justify-center text-lg sale-icon-box">
        <i class="fas fa-check"></i>
    </div>
    <div class="sale-info-box">
        <p class="text-sm font-bold text-slate-800 leading-tight mb-1" id="sale-product"></p>
        <p class="text-xs text-slate-500 sale-meta-text"><span id="sale-email" class="font-medium"></span> comprou há <span
                id="sale-time" class="font-medium text-slate-700"></span></p>
    </div>
</div>

<!-- Footer -->
<footer class="bg-slate-900 text-slate-400 py-12 border-t border-slate-800 custom-footer">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6 custom-footer-container">
        <div class="flex items-center gap-3 custom-footer-brand">
            <img src="/images/LogoHeader.png" alt="Logo" class="h-8 grayscale opacity-70 custom-footer-logo">
            <p class="text-sm custom-footer-copyright">© 2026 - Compras Livre Tec. Todos os direitos reservados.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-6 items-center custom-footer-links">
            <div class="flex gap-4 text-xl custom-footer-social">
                <a href="https://wa.me/5581985315669" class="hover:text-white transition"><i
                        class="fab fa-whatsapp"></i></a>
                <a href="https://www.instagram.com/compraslivre.tec/" class="hover:text-white transition"><i
                        class="fab fa-instagram"></i></a>
            </div>
        </div>
    </div>
</footer>

<script>
    // Notificações de Venda (Gatilho de Urgência/Prova Social)
    const salesData = [
        { product: "Suporte - Office 2024", time: "2 min", email: "jo****as@gmail.com" },
        { product: "Instalação CorelDRAW", time: "5 min", email: "ma****os@hotmail.com" },
        { product: "Manutenção Remota", time: "8 min", email: "ca****lo@outlook.com" },
        { product: "Suporte - Adobe Acrobat", time: "12 min", email: "fe****da@gmail.com" }
    ];

    function showNotification() {
        const sale = salesData[Math.floor(Math.random() * salesData.length)];
        const productElem = document.getElementById('sale-product');
        const emailElem = document.getElementById('sale-email');
        const timeElem = document.getElementById('sale-time');
        const notify = document.getElementById('sale-notification');

        if (!productElem || !emailElem || !timeElem || !notify) return;

        productElem.innerText = sale.product;
        emailElem.innerText = sale.email;
        timeElem.innerText = sale.time;

        notify.style.display = 'flex';
        notify.style.opacity = '0';
        notify.style.transform = 'translateY(20px)';

        // Fade in animation
        setTimeout(() => {
            notify.style.transition = 'all 0.5s ease';
            notify.style.opacity = '1';
            notify.style.transform = 'translateY(0)';
        }, 50);

        // Hide after 5 seconds
        setTimeout(() => {
            notify.style.opacity = '0';
            notify.style.transform = 'translateY(20px)';
            setTimeout(() => { notify.style.display = 'none'; }, 500);
        }, 5000);
    }

    // Iniciar notificações após alguns segundos
    setTimeout(() => {
        showNotification();
        setInterval(showNotification, Math.floor(Math.random() * (25000 - 15000 + 1) + 15000));
    }, 3000);
</script>
